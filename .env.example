NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_public_key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: base URL for guest portal links shown to hosts (short public links). Use https://stayvo.io in production
# so links match your marketing domain; defaults to NEXT_PUBLIC_APP_URL when unset.
# NEXT_PUBLIC_GUEST_LINK_BASE_URL=https://stayvo.io

# Optional: comma-separated hostnames for marketing (stayvo.io landing). Defaults to stayvo.io,www.stayvo.io
# NEXT_PUBLIC_MARKETING_HOSTS=stayvo.io,www.stayvo.io

# Server-only: Stripe webhooks update host_plan (Pro). Also used by Profile → Delete account.
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Guest/property images via Cloudflare R2 (optional). When all R2_* vars are set, uploads go to R2.
# Set NEXT_PUBLIC_GUEST_MEDIA_URL to the public base (R2.dev or custom domain), no trailing slash.
# Optional server-only duplicate of the same URL if NEXT_PUBLIC is missing at build time:
# GUEST_MEDIA_PUBLIC_URL=https://pub-xxxxx.r2.dev
# R2_ACCOUNT_ID=your_cloudflare_account_id
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=your_bucket_name
# NEXT_PUBLIC_GUEST_MEDIA_URL=https://pub-xxxxx.r2.dev

# Stripe (sandbox / test first). Price IDs from Dashboard → Product → Pricing (price_...).
# Webhook secret comes after you add https://app.stayvo.io/api/webhooks/stripe in Stripe.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRICE_ID_MONTHLY=price_...   # $9/month
# STRIPE_PRICE_ID_ANNUAL=price_...    # $90/year
# STRIPE_PRICE_ID=price_...           # optional legacy fallback for monthly only
# STRIPE_WEBHOOK_SECRET=whsec_...

